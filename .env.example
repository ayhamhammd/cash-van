NODE_ENV=development
PORT=3000

# Database
DB_HOST=db
DB_PORT=5432
DB_USERNAME=cashvan
DB_PASSWORD=cashvan_dev_pw
DB_NAME=cashvan
DB_SSL=false
DB_LOGGING=false

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Rate limit (requests per window per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# CORS (comma separated)
CORS_ORIGINS=*

# Local-disk object storage (cheque images, voice clips, etc.)
STORAGE_LOCAL_ROOT=./storage
STORAGE_PUBLIC_BASE_URL=/storage

# In-process AI / response cache (no Redis dependency)
CACHE_MAX_ENTRIES=5000
CACHE_DEFAULT_TTL_SEC=300

# Postgres-backed background jobs (pg-boss). Set to false to disable in tests.
JOBS_ENABLED=true

# JoFotara secret encryption key (AES-256-GCM, 32-byte hex / 64 chars).
# Generate with: openssl rand -hex 32
# REQUIRED in production. In development a deterministic dev-only key is used if missing.
JOFOTARA_KMS_KEY=

# Salt for HMAC-SHA256 phone hashing (PII-safe AI references).
# REQUIRED in production (>= 16 chars). Dev fallback used if missing.
PHONE_HASH_SECRET=

# Mock the ISTD JoFotara submission. Keep true until you have real sandbox
# credentials AND have verified the JoFotara API contract/URLs.
JOFOTARA_MOCK=true

# --- AI report agent --------------------------------------------------------
# Which LLM vendor drives the agent: 'anthropic' (Claude) or 'gemini' (Google).
# Only the selected provider's API key is required (a clean error is streamed
# if it's missing).
LLM_PROVIDER=anthropic

# Anthropic Claude (used when LLM_PROVIDER=anthropic). Key from
# https://console.anthropic.com/ — billed separately from Claude Pro/Max.
ANTHROPIC_API_KEY=
# claude-sonnet-4-6 = good default; claude-opus-4-8 = most capable;
# claude-haiku-4-5-20251001 = cheapest.
AGENT_MODEL=claude-sonnet-4-6

# Google Gemini (used when LLM_PROVIDER=gemini). Free-tier key from
# https://aistudio.google.com/  ⚠️ free-tier inputs may be used by Google to
# improve their products — avoid for sensitive data; use a paid/Vertex key there.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

AGENT_MAX_TOKENS=4096
# Max tool-use round-trips per chat turn (safety cap on the agent loop).
AGENT_MAX_ITERATIONS=8
# Rows the agent sees when it previews a query (keeps the model context small).
AGENT_SQL_PREVIEW_ROWS=50
# Hard ceiling on rows pulled into a generated report file.
AGENT_SQL_ROW_LIMIT=5000
# Per-statement timeout (ms) for the agent's read-only queries.
AGENT_SQL_TIMEOUT_MS=15000

# Dedicated read-only Postgres role for the agent's generated SQL. Create it
# once with scripts/sql/report-agent-role.sql. Host/port/db come from DB_*.
# REQUIRED in production. In dev, leave REPORT_DB_PASSWORD blank to fall back
# to DB_USERNAME/DB_PASSWORD (a read-only transaction is still enforced).
REPORT_DB_USER=report_agent
REPORT_DB_PASSWORD=

# ERP → VanFlow push webhook shared secret (must match ERP VANFLOW_WEBHOOK_SECRET)
ERP_WEBHOOK_SECRET=
