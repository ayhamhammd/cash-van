NODE_ENV=development
PORT=3000

# Database
DB_HOST=db
DB_PORT=5432
DB_USERNAME=cashvan
DB_PASSWORD=cashvan_dev_pw
DB_NAME=cashvan
DB_SSL=false
DB_LOGGING=false

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# Rate limit (requests per window per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# CORS (comma separated)
CORS_ORIGINS=*

# Local-disk object storage (cheque images, voice clips, etc.)
STORAGE_LOCAL_ROOT=./storage
STORAGE_PUBLIC_BASE_URL=/storage

# In-process AI / response cache (no Redis dependency)
CACHE_MAX_ENTRIES=5000
CACHE_DEFAULT_TTL_SEC=300

# Postgres-backed background jobs (pg-boss). Set to false to disable in tests.
JOBS_ENABLED=true

# JoFotara secret encryption key (AES-256-GCM, 32-byte hex / 64 chars).
# Generate with: openssl rand -hex 32
# REQUIRED in production. In development a deterministic dev-only key is used if missing.
JOFOTARA_KMS_KEY=

# Salt for HMAC-SHA256 phone hashing (PII-safe AI references).
# REQUIRED in production (>= 16 chars). Dev fallback used if missing.
PHONE_HASH_SECRET=

# Mock the ISTD JoFotara submission. Keep true until you have real sandbox
# credentials AND have verified the JoFotara API contract/URLs.
JOFOTARA_MOCK=true
