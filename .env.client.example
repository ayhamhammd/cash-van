# ── VanFlow API — on-prem client .env ────────────────────────────────────────
# Copy to ".env" next to docker-compose.client.yml and fill in the secrets.
#   cp .env.client.example .env
# Generate each secret with the command shown in its comment (needs `openssl`).

NODE_ENV=production
PORT=3000

# Clean install: create only the default admin login, NOT the demo catalog /
# customers / reps / offers. Set to true only if you want the sample data.
SEED_DEMO=false

# ── Database (bundled Postgres — DB_HOST is set to "db" by the compose file) ──
DB_USERNAME=cashvan
DB_PASSWORD=CHANGE_ME                 # openssl rand -hex 16
DB_NAME=cashvan
DB_SSL=false
DB_LOGGING=false

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME                  # openssl rand -hex 32   (min 16 chars)
JWT_EXPIRES_IN=12h

# ── Production secrets (REQUIRED — the API refuses to boot without them) ──────
JOFOTARA_KMS_KEY=CHANGE_ME            # openssl rand -hex 32   (exactly 64 hex chars)
PHONE_HASH_SECRET=CHANGE_ME           # openssl rand -hex 16   (min 16 chars)

# ── LAN access ───────────────────────────────────────────────────────────────
# "*" lets any device on the local network talk to the API. Fine for on-prem.
CORS_ORIGINS=*
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ── Jordan e-invoicing (JoFotara) ────────────────────────────────────────────
# Keep mocked until real ISTD sandbox credentials + contract are wired up.
JOFOTARA_MOCK=true

# ── AI report agent (OPTIONAL) ───────────────────────────────────────────────
# Leave blank to run without the AI insights feature. To enable, set a key.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# Read-only DB role for the AI agent — optional on-prem; blank falls back to the
# main DB user (a read-only transaction is still enforced).
REPORT_DB_USER=report_agent
REPORT_DB_PASSWORD=

# ERP push webhook secret — only needed if an ERP pushes catalog/customers here.
ERP_WEBHOOK_SECRET=
